# ---------------------------------------------------------------------------
# Large datasets, model weights, checkpoints, and generated artifacts
# are NOT stored in this repository. Use external storage (HF Hub, R2, S3).
# Allowed in-repo: .gitkeep, README.md, and small files under samples/
# ---------------------------------------------------------------------------

# Dataset directories
data/datasets/raw/*
!data/datasets/raw/.gitkeep
!data/datasets/raw/README.md

data/datasets/processed/*
!data/datasets/processed/.gitkeep
!data/datasets/processed/README.md

# Model artifacts
models/*
!models/.gitkeep
!models/README.md

# Training experiment outputs
training/experiments/*
!training/experiments/.gitkeep

training/**/wandb/
training/**/runs/
training/**/logs/

# Evaluation outputs
evaluation/reports/*
!evaluation/reports/.gitkeep

evaluation/benchmarks/results/

# Generated outputs and checkpoints
outputs/*
!outputs/.gitkeep
!outputs/README.md

checkpoints/*
!checkpoints/.gitkeep

# Large binary and data file formats (repo-wide)
*.safetensors
*.bin
*.pt
*.pth
*.ckpt
*.gguf
*.parquet
*.jsonl
*.arrow
*.csv
*.zip
*.tar
*.tar.gz

# Small sample files only — exception to rules above
!samples/
!samples/**

# Evaluation harness benchmark JSONL (small curated files only)
!evaluation/datasets/
!evaluation/datasets/*.jsonl

# Evaluation run artifacts (generated locally)
evaluation/results/*.json
evaluation/reports/leaderboard.json
evaluation/reports/regression_*.json
evaluation/reports/regression_*.md

# Secrets & environment
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
secrets/

# Logs & temp
*.log
logs/
tmp/
temp/
.cache/

# Coverage & test artifacts
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
