# ArabArenaAI-1 Evaluation Harness — environment variables
# Copy to .env and fill values. Never commit .env.

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEMPERATURE=0

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_TEMPERATURE=0

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-flash
GOOGLE_TEMPERATURE=0

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_TEMPERATURE=0

# Ollama (local Qwen via `ollama run qwen3:8b`)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
QWEN_MODEL=qwen3:8b
OLLAMA_TIMEOUT=120
OLLAMA_TEMPERATURE=0

# Other local models (future HF)
LLAMA_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# Workspace layer (Phase Next — default off)
WORKSPACE_ENABLED=false
# Local dev example: postgresql+psycopg://USER:PASSWORD@localhost:5432/arabarena_workspace
WORKSPACE_DATABASE_URL=
